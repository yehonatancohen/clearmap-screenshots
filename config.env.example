# Telegram Bot Token (same as the brain service)
CLEARMAP_BOT_TOKEN=your_bot_token_here

# Telegram channel to broadcast to
TELEGRAM_CHANNEL_ID=-1003879479829

# URL of the ClearMap frontend
SCREENSHOT_URL=https://clearmap.co.il

# Screenshot cooldown in seconds (minimum time between broadcasts)
SCREENSHOT_COOLDOWN=120

# Sliding window delay in seconds (batches rapid alerts)
SCREENSHOT_BATCH_DELAY=10

# Firebase service account JSON (paste full JSON or base64-encoded)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
